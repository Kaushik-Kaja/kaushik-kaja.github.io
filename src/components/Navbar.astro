---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="#" class="font-mono text-sm tracking-wider hoverable">
      <span class="gradient-text font-bold">KK</span><span class="text-white/20">.</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-white/40 hover:text-white transition-colors duration-300 hoverable"
        >
          {link.label}
        </a>
      ))}
      <a
        href="mailto:kaushikskaja@gmail.com"
        class="text-sm px-5 py-2 rounded-full border border-white/10 text-white/50 hover:border-[#fd321c]/40 hover:text-white transition-all duration-300 hoverable"
      >
        Get in touch
      </a>
    </div>

    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 hoverable" aria-label="Menu">
      <span class="w-6 h-px bg-white/60 transition-all duration-300"></span>
      <span class="w-4 h-px bg-white/60 transition-all duration-300"></span>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden fixed inset-0 bg-black/95 backdrop-blur-xl z-40 flex flex-col items-center justify-center gap-8">
    {links.map((link) => (
      <a
        href={link.href}
        class="text-2xl text-white/50 hover:text-white transition-colors duration-300 mobile-link"
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-black/60', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    } else {
      navbar.classList.remove('bg-black/60', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    }
  });

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });

  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
    });
  });
</script>
