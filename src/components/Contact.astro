<section id="contact" class="py-32 px-6 relative">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-gradient-to-t from-[#fd321c]/10 to-transparent blur-[120px] pointer-events-none"></div>

  <div class="max-w-5xl mx-auto text-center relative z-10">
    <span class="section-num left-1/2 -translate-x-1/2">05</span>

    <div class="reveal">
      <p class="font-mono text-sm tracking-[0.2em] mb-4 gradient-text">CONTACT</p>
      <h2 class="text-4xl md:text-6xl font-bold mb-6">
        Let's <span class="gradient-text">connect</span>
      </h2>
      <p class="text-white/35 max-w-md mx-auto mb-12 text-lg">
        I'm always open to new opportunities and interesting conversations.
        Feel free to reach out.
      </p>
    </div>

    <div class="reveal">
      <a
        href="mailto:kaushikskaja@gmail.com"
        class="inline-block px-10 py-4 bg-gradient-to-r from-[#fd321c] to-[#ff8a00] text-white text-sm font-medium tracking-wider rounded-full hover:opacity-90 transition-all duration-300 magnetic hoverable"
      >
        SAY HELLO ↗
      </a>
    </div>

    <div class="reveal flex items-center justify-center gap-10 mt-16">
      <a
        href="https://github.com/Kaushik-Kaja"
        target="_blank"
        rel="noopener"
        class="text-white/25 hover:text-white text-sm font-medium transition-colors duration-300 hoverable"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/kaushikskaja"
        target="_blank"
        rel="noopener"
        class="text-white/25 hover:text-white text-sm font-medium transition-colors duration-300 hoverable"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>

<footer class="py-8 text-center border-t border-white/[0.03]">
  <p class="text-white/10 text-xs font-mono">
    Designed & Built by Kaushik Kaja
  </p>
</footer>
